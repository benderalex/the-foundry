# GITHUB_TOKEN is optional for the skeleton — `gh` CLI uses its own auth.
# Fill in when real GitHub API / LLM-side calls land.
# GITHUB_TOKEN=ghp_...
SOURCE_REPO=your-org/the-foundry-sandbox
TARGET_REPO=your-org/the-foundry-sandbox
ISSUE_LABEL=agent-task
WORKTREE_ROOT=./worktrees
DB_PATH=./data/foundry.sqlite
POLL_INTERVAL_SECONDS=30

# --- coding agents (foundry.agents) ---
# One backend/model/timeout applies to all three stages by default.
# Per-stage overrides (AGENT_PLAN_*, AGENT_IMPLEMENT_*, AGENT_VERIFY_*) win
# over the global defaults.

# Default backend: stub | claude_cli
CODING_AGENT=stub
# Default model (claude_cli accepts haiku|sonnet|opus|<full-id>)
AGENT_MODEL=haiku
# Default wall-clock timeout per apply(), seconds
AGENT_TIMEOUT_SEC=300
# Default agentic turn cap (ignored by stub)
AGENT_MAX_TURNS=10

# --- per-stage overrides (optional) ---
# AGENT_PLAN_MODEL=haiku
# AGENT_IMPLEMENT_MODEL=sonnet
# AGENT_VERIFY_MODEL=haiku
# AGENT_PLAN_MAX_TURNS=5
# AGENT_IMPLEMENT_MAX_TURNS=30
# AGENT_VERIFY_MAX_TURNS=5
# AGENT_IMPLEMENT_BACKEND=claude_cli
